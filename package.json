{
  "name": "nuurhome-backend",
  "version": "1.0.0",
  "description": "Custom backend for NuurHome ecosystem",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "seed": "node prisma/seed.js",
    "sync:categories:dry": "node scripts/sync-categories-from-nuur.js --dry-run",
    "sync:categories": "node scripts/sync-categories-from-nuur.js",
    "sync:products:dry": "node scripts/sync-products-from-nuur.js --dry-run",
    "sync:products": "node scripts/sync-products-from-nuur.js",
    "clear:migrated-colors:dry": "node scripts/clear-migrated-product-colors.js --dry-run",
    "clear:migrated-colors": "node scripts/clear-migrated-product-colors.js"
  },
  "dependencies": {
    "@prisma/client": "^5.x",
    "@supabase/supabase-js": "^2.104.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "prisma": "^5.x"
  }
}
