// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CORE MODELS ---

enum Role {
  ADMIN
  ERP
  SELLER
  USER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullname  String?
  phone     String?
  address   String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions Transaction[]
  orders       Order[]
  reviews      Review[]
  employee     Employee?
}

model Category {
  id          String    @id @default(uuid())
  name        String?   // Legacy
  name_uz     String?
  name_ru     String?
  name_en     String?
  slug        String    @unique
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             String      @id @default(uuid())
  categoryId     String
  category       Category    @relation(fields: [categoryId], references: [id])
  
  // Multilingual Names
  name           String?     // Legacy
  name_uz        String?
  name_ru        String?
  name_en        String?

  // Multilingual Descriptions
  description    String?     // Legacy
  description_uz String?
  description_ru String?
  description_en String?

  sku            String?     // Product Code (Table 'size' field)
  price          Decimal     @db.Decimal(15, 2)
  stock          Decimal     @default(0) @db.Decimal(12, 3) 
  isKg           Boolean     @default(false)
  images         Json?       // Array of strings
  features       Json?       // Characteristics [{k: "key", v: "val"}]
  colors         Json?       // Array of color strings
  
  rating         Decimal     @default(0) @db.Decimal(3, 2)
  reviews        Int         @default(0)
  rope_weight_kg Decimal?    @db.Decimal(10, 3)

  sortOrder      Int         @default(0)
  model3dUrl     String?
  showInNew      Boolean     @default(false)
  isActive       Boolean     @default(true)
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orderItems     OrderItem[]
  inventory      ProductInventory[]
  reviewsList    Review[]
}

model Order {
  id                    String        @id @default(uuid())
  order_number          Int           @unique @default(autoincrement())
  customer_name         String?
  customer_phone        String?
  total                 Decimal       @default(0) @db.Decimal(15, 2)
  status                String        @default("new")
  source                String?       @default("dokon")
  note                  String?
  receipt_url           String?
  payment_method_detail String?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  created_by            String?
  user                  User?         @relation(fields: [created_by], references: [id])
  
  deleted_at            DateTime?     
  
  order_items           OrderItem[]
  transactions          Transaction[]
}

// Status is just string natively

model OrderItem {
  id             String   @id @default(uuid())
  order_id       String
  order          Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product_id     String?
  product        Product? @relation(fields: [product_id], references: [id])
  product_name   String?
  quantity       Decimal  @db.Decimal(12, 3)
  product_price  Decimal  @db.Decimal(15, 2)
  image_url      String?
  sku            String?
  rope_weight_kg Decimal? @db.Decimal(10, 3)
  size           String?
  color          String?
  local_note     String?
}

model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  category    String?         // E.g., 'Savdo', 'Xarid', 'Oylik'
  description String
  date        DateTime        @default(now())
  
  orderId     String?
  order       Order?          @relation(fields: [orderId], references: [id])
  
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  
  createdAt   DateTime        @default(now())
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Color {
  id        String   @id @default(uuid())
  name      String   @unique
  hex       String?  // Optional hex code
  createdAt DateTime @default(now())
}

// --- FINANCE MODELS ---

model Department {
  id          String   @id @default(uuid())
  name_uz     String?
  name_ru     String?
  name_en     String?
  parent_id   String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materialMovements MaterialMovement[]
}

model FinancePartner {
  id          String   @id @default(uuid())
  name_uz     String?
  name_ru     String?
  name_en     String?
  type        String?  // E.g., 'Supplier', 'Buyer'
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  financeEntries PartnerFinanceEntry[]
}

model PartnerFinanceEntry {
  id                 String   @id @default(uuid())
  partner_id         String
  partner            FinancePartner @relation(fields: [partner_id], references: [id])
  entry_type         String   // 'supply', 'payment', 'payment_in', 'sale_out'
  amount_uzs         Decimal  @db.Decimal(15, 2)
  currency           String   @default("UZS")
  entry_date         String   // YYYY-MM-DD
  description        String?
  responsible_person String?
  warehouse          String?
  status             String   @default("completed")
  createdAt          DateTime @default(now())

  lines              PartnerFinanceEntryLine[]
}

model PartnerFinanceEntryLine {
  id               String              @id @default(uuid())
  entry_id         String
  entry            PartnerFinanceEntry @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  item_name        String
  quantity_display String
  unit_price_uzs   Decimal             @db.Decimal(15, 2)
  line_total_uzs   Decimal             @db.Decimal(15, 2)
  createdAt        DateTime            @default(now())
}

model MaterialMovement {
  id                   String     @id @default(uuid())
  department_id        String
  department           Department @relation(fields: [department_id], references: [id])
  raw_material_id      String?
  unit_price_snapshot  Decimal?   @db.Decimal(15, 2)
  total_cost           Decimal    @db.Decimal(15, 2)
  movement_date        String     // YYYY-MM-DD
  currency             String     @default("UZS")
  note                 String?
  createdAt            DateTime   @default(now())
}

model Employee {
  id             String   @id @default(uuid())
  name           String
  phone          String?
  position       String?  
  monthly_salary Decimal  @default(0) @db.Decimal(15, 2)
  bonus_percent  Decimal  @default(0) @db.Decimal(15, 2)
  worked_days    Int      @default(0)
  rest_days      Int      @default(0)
  isActive       Boolean  @default(true)
  
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id])
  
  advances       EmployeeAdvance[]
  salaries       EmployeeSalaryPayment[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EmployeeAdvance {
  id           String   @id @default(uuid())
  employee_id  String
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  amount       Decimal  @db.Decimal(15, 2)
  advance_date String   // YYYY-MM-DD
  note         String?
  createdAt    DateTime @default(now())
}

model EmployeeSalaryPayment {
  id           String   @id @default(uuid())
  employee_id  String
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  amount       Decimal  @db.Decimal(15, 2)
  payment_date String   // YYYY-MM-DD
  note         String?
  createdAt    DateTime @default(now())
}

model ExcelImportHistory {
  id          String   @id @default(uuid())
  fileName    String
  importDate  DateTime @default(now())
  items       Json?    // Aggregated Excel items [{model_code, color, quantity, product_name}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmployeePayrollMonthClosure {
  id        String   @id @default(uuid())
  period_ym String   @unique // "YYYY-MM"
  source    String?  @default("crm")
  createdAt DateTime @default(now())
}

model EmployeeLeaveRequest {
  id          String   @id @default(uuid())
  employee_id String
  status      String   @default("approved")
  resolved_at DateTime?
  createdAt   DateTime @default(now())
}

model ProductInventory {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id])
  colorKey   String?  @map("color_key")
  stock      Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([productId, colorKey])
  @@map("product_inventory")
}

model StockMovement {
  id            String   @id @default(uuid())
  productId     String?  @map("product_id")
  colorKey      String?  @map("color_key")
  qty           Decimal  @db.Decimal(12, 3)
  type          String   // 'in', 'out'
  orderId       String?  @map("order_id")
  orderNumber   Int?     @map("order_number")
  customerName  String?  @map("customer_name")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("stock_movements")
}

model Review {
  id                  String   @id @default(uuid())
  product_id          String
  product             Product  @relation(fields: [product_id], references: [id])
  user_id             String?
  user                User?    @relation(fields: [user_id], references: [id])
  author_display_name String?
  rating              Int      @default(5)
  comment             String
  status              String   @default("approved") // approved, pending, rejected
  created_at          DateTime @default(now())
}

model ContactMessage {
  id         String   @id @default(uuid())
  name       String
  email      String?
  phone      String?
  subject    String?
  message    String
  status     String   @default("new") // new, read, replied
  created_at DateTime @default(now())
}

model AlbumImage {
  id         String   @id @default(uuid())
  image_url  String
  title_uz   String?
  title_ru   String?
  title_en   String?
  format     String?  @default("portrait") // portrait, landscape, square, large
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

model SiteSetting {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String?
  description   String?
  updated_at    DateTime @updatedAt
}

model Banner {
  id         String   @id @default(uuid())
  image_url  String
  title_uz   String?
  title_ru   String?
  title_en   String?
  link_url   String?
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
}

model SiteBenefit {
  id         String   @id @default(uuid())
  icon       String?  // Lucide icon name
  title_uz   String?
  title_ru   String?
  title_en   String?
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
}
